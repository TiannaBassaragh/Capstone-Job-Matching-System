DATABASE_URL='postgresql+psycopg2://username:password@localhost:5432/job_matching_system'
SECRET_KEY=your_secret_key_here

# LLM provider: "anthropic" (default) or "gemini" (free tier)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend origin for CORS. Set to your deployed frontend URL in production.
FRONTEND_URL=http://localhost:3000